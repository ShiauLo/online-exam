# Copy this file to ".env" before running docker compose.

COMPOSE_PROJECT_NAME=online-exam-infra
HOST_BIND_IP=127.0.0.1
TZ=Asia/Shanghai

MYSQL_PORT=3306
MYSQL_DATABASE=online_exam_db
MYSQL_ROOT_PASSWORD=ChangeThisMySQLPassword_2026
MYSQL_ROOT_HOST=%
EXAM_DB_HOST=127.0.0.1
EXAM_DB_PORT=3306
EXAM_DB_NAME=online_exam_db
EXAM_DB_USERNAME=root

REDIS_PORT=6379
REDIS_PASSWORD=ChangeThisRedisPassword_2026
EXAM_REDIS_HOST=127.0.0.1
EXAM_REDIS_PORT=6379
EXAM_REDIS_DATABASE=0

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=online_exam
RABBITMQ_DEFAULT_PASS=ChangeThisRabbitMqPassword_2026
RABBITMQ_DEFAULT_VHOST=/online-exam

NACOS_PORT=8848
NACOS_RAFT_PORT=9848
NACOS_GRPC_PORT=9849
NACOS_MYSQL_DATABASE=nacos_config
NACOS_MYSQL_USER=root
NACOS_MYSQL_PASSWORD=ChangeThisMySQLPassword_2026
NACOS_MYSQL_DB_PARAM=characterEncoding=utf8&connectTimeout=1000&socketTimeout=3000&autoReconnect=true&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
NACOS_AUTH_TOKEN=VGhpc0lzQVN0cm9uZ05hY29zQXV0aFRva2VuRm9yMjAyNg==
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security
NACOS_JVM_XMS=256m
NACOS_JVM_XMX=256m
NACOS_JVM_XMN=128m
EXAM_NACOS_ADDR=127.0.0.1:8848
EXAM_NACOS_USERNAME=nacos
EXAM_NACOS_PASSWORD=nacos
EXAM_NACOS_ENABLED=true
EXAM_ACCOUNT_ROUTE_URI=lb://exam-account
EXAM_CLASS_ROUTE_URI=lb://exam-class
EXAM_CORE_ROUTE_URI=lb://exam-core
EXAM_REALTIME_ROUTE_URI=lb://exam-realtime
EXAM_JAVA_BUILD_OPTS="-Xms128m -Xmx256m -XX:MaxMetaspaceSize=128m"
EXAM_JAVA_START_OPTS="-Xms96m -Xmx256m -XX:MaxMetaspaceSize=128m"
